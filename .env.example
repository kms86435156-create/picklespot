# ──────────────────────────────────────────────
# 피클볼 플랫폼 환경변수 설정 가이드
# 이 파일을 .env로 복사하고 값을 채우세요
# ──────────────────────────────────────────────

# ── DB 모드 설정 ──────────────────────────────
# JSON 파일 모드 강제 (로컬 개발/테스트 시)
# true  → data/*.json 파일에 저장 (서버 재시작 시 유지, Vercel 배포 시 휘발)
# false → Supabase PostgreSQL 사용 (아래 키 필요)
# 미설정 → Supabase URL/KEY 유무로 자동 판단
SUPABASE_DISABLED=true

# ── Supabase 설정 (SUPABASE_DISABLED=false 또는 미설정 시 필요) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── JWT 인증 ──────────────────────────────────
# 32자 이상 랜덤 문자열 권장
JWT_SECRET=your-secret-key-min-32-chars

# ── 사이트 URL ────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ── Kakao Map (선택) ──────────────────────────
NEXT_PUBLIC_KAKAO_MAP_KEY=

# ── SQLite (레거시, 미사용) ───────────────────
DATABASE_URL="file:./dev.db"
